# ============================================================
# Writers Block - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ----------------------------------------------------------
# Site Configuration
# ----------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: shown as mailto in marketing footer "Contact" when set (otherwise links to Siru AI Labs site)
# NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com

# ----------------------------------------------------------
# Supabase Configuration
# Get these from your Supabase project settings
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (server-side only — never expose to client)
# Required for: webhook handler, admin dashboard, cron jobs
# Get from: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database connection pooler (for serverless functions)
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_DATABASE_URL=your_supabase_connection_pooler_url

# ----------------------------------------------------------
# AI/ML API Keys
# ----------------------------------------------------------

# Replicate API Token (screenplay + shots; default model is Gemini 2.5 Flash)
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_replicate_token_here
# Default: google/gemini-2.5-flash. Set to e.g. meta/meta-llama-3-8b-instruct for a lighter free tier.
REPLICATE_MODEL=google/gemini-2.5-flash
# Plan-specific overrides (optional). Falls back to REPLICATE_MODEL per tier.
# REPLICATE_MODEL_FREE=meta/meta-llama-3-8b-instruct
# REPLICATE_MODEL_PRO=google/gemini-2.5-flash
# REPLICATE_MODEL_PREMIUM=google/gemini-2.5-flash

# Maximum tokens for generation (maps to max_output_tokens for Gemini; max_tokens for Llama)
MAX_TOKENS=8000

# Anthropic API Key (used by /api/movie-references on the server)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# ----------------------------------------------------------
# Redis/Rate Limiting (Upstash)
# Required for distributed rate limiting
# Get from: https://console.upstash.com
# ----------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Production / next start: AI routes return 503 if Redis env vars are missing.
# Set only for emergencies or self-hosted setups without Upstash (not recommended):
# ALLOW_AI_WITHOUT_REDIS=1

# ----------------------------------------------------------
# Payment Processing (Razorpay)
# Get from: https://dashboard.razorpay.com
# ----------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Webhook secret for server-side payment verification
# Set this in: Razorpay Dashboard → Settings → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ----------------------------------------------------------
# Pricing (in Indian Paise — 1 INR = 100 paise)
# Override these to change prices without a code deploy
# ----------------------------------------------------------
PRO_MONTHLY_PRICE_PAISE=119900
PRO_ANNUAL_PRICE_PAISE=1151000
PREMIUM_MONTHLY_PRICE_PAISE=399900
PREMIUM_ANNUAL_PRICE_PAISE=3839000

# ----------------------------------------------------------
# Email Notifications (Resend)
# Get from: https://resend.com
# ----------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@writersblock.app

# ----------------------------------------------------------
# Admin access (database — not env email lists)
# Guide: docs/admin-operators.md
# After running supabase/database.sql, grant operators with:
#   INSERT INTO public.master_admin_users (user_id, note)
#   VALUES ('<uuid from auth.users>', 'founder');
# Same auth users still have rows in public.profiles; privileges are only in master_admin_users.
# Requires SUPABASE_SERVICE_ROLE_KEY for checks (middleware + APIs). ADMIN_EMAILS is unused.
# ----------------------------------------------------------

# Master Admin — comma-separated Host header values (include port for non-443 dev)
# Example production: admin.writersblock.siru.ai
# Example local: localhost:3000
# If empty, /master-admin and /api/master-admin return 404 on all hosts (fail closed).
ADMIN_HOSTS=localhost:3000

# ----------------------------------------------------------
# Cron Jobs (Vercel)
# Set this in Vercel project settings → Environment Variables
# Used to protect /api/cron/* endpoints.
# Production (VERCEL_ENV or NODE_ENV=production): REQUIRED — cron returns 503 if unset; calls must send Authorization: Bearer <CRON_SECRET>.
# Local dev: optional; if set, same Bearer header is required.
# ----------------------------------------------------------
CRON_SECRET=your_random_cron_secret_here

# ----------------------------------------------------------
# Optional: Sentry (error monitoring)
# Client + server init when DSN is set; events scrub auth cookies/headers (see lib/sentry-scrub.ts).
# Source map upload in CI: set SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT (build uses dryRun when token absent).
# ----------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# SENTRY_DSN=  # optional server-only override
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ----------------------------------------------------------
# Optional: Queue System (Upstash QStash)
# For async processing of AI generation (future feature)
# ----------------------------------------------------------
QSTASH_TOKEN=your_qstash_token
QSTASH_CURRENT_SIGNING_KEY=your_qstash_signing_key
QSTASH_NEXT_SIGNING_KEY=your_qstash_next_signing_key

# ----------------------------------------------------------
# Development Settings
# ----------------------------------------------------------
# Set to true to disable rate limiting in development
DISABLE_RATE_LIMIT=false

# Debug mode for verbose logging
DEBUG=false
